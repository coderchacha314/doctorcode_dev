# DoctorCode — Environment Variables Template
# Copy this file to .env.local and fill in your values
# DO NOT add real values to this file — it is committed to git

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Use "Transaction" mode (port 6543) for DATABASE_URL
# Use "Session" mode (port 5432) for DIRECT_URL
DATABASE_URL=
DIRECT_URL=

# ─── Resend ──────────────────────────────────────────────────────────────────
# Get from: Resend Dashboard → API Keys
RESEND_API_KEY=
# The "from" address for outgoing emails (must be a verified domain)
RESEND_FROM_EMAIL=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Get from: Cloudinary Dashboard → Settings → Access Keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Create an unsigned upload preset in Cloudinary → Settings → Upload
CLOUDINARY_UPLOAD_PRESET=

# ─── Render ──────────────────────────────────────────────────────────────────
# Get from: Render Dashboard → Account Settings → API Keys
RENDER_API_KEY=
# Optional: deploy hook URLs for manual triggers
RENDER_DEPLOY_HOOK_DEV=
RENDER_DEPLOY_HOOK_PROD=

# ─── App ─────────────────────────────────────────────────────────────────────
# The public URL of the app (used for email links, redirects)
# local: http://localhost:3000 | dev: https://dev.doctorcode.app | prod: https://doctorcode.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# development | production
NODE_ENV=development
